        <mxCell id="reviewApp" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3F51B5;strokeColor=#283593;fontColor=#ffffff;fontSize=11;arcSize=8;" value="&lt;b&gt;Review UI&lt;/b&gt; — review_app/m6.html + m6.js&#10;static, served at localhost:8000&#10;per-question evidence · edit · approve/reject&#10;&lt;i&gt;blocks rubber-stamping a flagged item&lt;/i&gt;">
