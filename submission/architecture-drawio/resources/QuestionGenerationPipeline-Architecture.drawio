        <mxCell id="decisions" parent="1" vertex="1" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#000000;fontSize=11;align=center;verticalAlign=middle;" value="review/m6-decisions.json&#10;(exported decisions)">
