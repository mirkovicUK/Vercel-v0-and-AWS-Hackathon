        <mxCell id="reviewer" parent="1" vertex="1" style="sketch=0;outlineConnect=0;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;shape=mxgraph.aws3.user;fillColor=#3F51B5;gradientColor=none;" value="">
